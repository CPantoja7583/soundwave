<section class="hero">
  <div>
    <p class="eyebrow">Proyecto grupal</p>
    <h1 class="hero-title">Catalogo musical colaborativo</h1>
    <p class="lede">
      SoundWave mezcla API REST, vistas Handlebars y Sequelize en una base que el equipo puede seguir expandiendo.
    </p>
  </div>

  <div class="shuffle-card">
    <p class="eyebrow">Shuffle sugerido</p>
    {{#if shuffle}}
      <div class="shuffle-main" data-shuffle-card>
        <img src="/img/shuffle-logo.svg" alt="Shuffle" class="shuffle-icon">

        <div class="shuffle-text">
          <strong data-shuffle-title>{{shuffle.titulo}}</strong>
          <span data-shuffle-meta>{{shuffle.artista.nombre}} &middot; {{shuffle.duracionTexto}}</span>
        </div>

        <button class="shuffle-btn" type="button" data-shuffle-button>
          Shuffle
        </button>
      </div>
    {{else}}
      <p class="empty-state">No hay canciones disponibles para shuffle.</p>
    {{/if}}
  </div>
</section>

{{#if feedback}}
  <section class="notice notice--{{feedback.tone}}" aria-live="polite">
    <p>{{feedback.message}}</p>
  </section>
{{/if}}

<section class="panel">
  <div class="panel-head">
    <h2>Filtrar por genero</h2>
  </div>

  <form class="filter-form" method="GET" action="/">
    <select id="genero-filter" name="genero" aria-label="Filtrar artistas por genero">
      <option value="">Todos los generos</option>
      {{#each generos}}
        <option value="{{this}}" {{#if (eq ../filtroGenero this)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
    <button class="btn-filter-apply" type="submit">Aplicar</button>
    <a class="btn-filter-clear" href="/">Limpiar</a>
  </form>
</section>

<section class="grid-layout">
  <div class="panel">
    <div class="panel-head">
      <h2>Artistas</h2>
      <span class="count-pill">{{artistas.length}} encontrados</span>
    </div>

    {{#if artistas.length}}
      <div class="artist-grid">
        {{#each artistas}}
          {{> artista-card}}
        {{/each}}
      </div>
    {{else}}
      <p class="empty-state">No hay artistas para este filtro todavia.</p>
    {{/if}}
  </div>

  <aside class="panel sidebar">
    <div class="panel-head">
      <h2>Top 10</h2>
    </div>

    {{#if topCanciones.length}}
      <ol class="top-list">
        {{#each topCanciones}}
          <li>
            <span class="top-num"></span>
            <div class="top-info">
              <strong>{{titulo}}</strong>
              <span>{{artista.nombre}} &middot; {{duracionTexto}}</span>
            </div>
            <span class="top-plays">{{reproducciones}}</span>
          </li>
        {{/each}}
      </ol>
    {{else}}
      <p class="empty-state">Aun no hay canciones en ranking.</p>
    {{/if}}
  </aside>
</section>

