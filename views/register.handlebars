<section class="auth-shell">
  <div class="auth-card">
    <a class="auth-brand" href="/" aria-label="Volver al inicio de SoundWave">
      <span class="auth-brand__mark">~</span>
      <span>SoundWave</span>
    </a>

    <div class="auth-heading">
      <p class="auth-eyebrow">Registro</p>
      <h1 class="form-title">Crea tu cuenta</h1>
      <p class="form-intro">Únete para colaborar en el catálogo musical del equipo.</p>
    </div>

    {{#if errorMessage}}
      <p class="error-text" aria-live="polite">{{errorMessage}}</p>
    {{/if}}

    <form class="stack-form auth-form" method="POST" action="/register">
      <input type="hidden" name="next" value="{{next}}" />

      <label>
        Nombre
        <input type="text" name="nombre" value="{{nombre}}" autocomplete="name" minlength="2" required />
      </label>

      <label>
        Email
        <input type="email" name="email" value="{{email}}" autocomplete="email" required />
      </label>

      <label>
        Contraseña
        <input type="password" name="password" autocomplete="new-password" minlength="8" required />
      </label>

      <label>
        Repetir contraseña
        <input type="password" name="passwordConfirm" autocomplete="new-password" minlength="8" required />
      </label>

      <button class="button auth-submit" type="submit">Crear cuenta</button>
    </form>

    <div class="auth-separator"><span>o usa un proveedor</span></div>

    <div class="oauth-actions" aria-label="Opciones de registro externas">
      {{#if googleEnabled}}
        <a class="button button--ghost oauth-button" href="/auth/google?next={{encodeURIComponent next}}">Registrarse con Google</a>
      {{else}}
        <span class="button button--ghost oauth-button oauth-button--disabled" aria-disabled="true">Google no configurado</span>
      {{/if}}

      {{#if microsoftEnabled}}
        <a class="button button--ghost oauth-button" href="/auth/microsoft?next={{encodeURIComponent next}}">Registrarse con Microsoft</a>
      {{else}}
        <span class="button button--ghost oauth-button oauth-button--disabled" aria-disabled="true">Microsoft no configurado</span>
      {{/if}}
    </div>

    <p class="auth-switch">
      ¿Ya tienes cuenta?
      <a href="/login?next={{encodeURIComponent next}}">Inicia sesión</a>
    </p>
  </div>
</section>
