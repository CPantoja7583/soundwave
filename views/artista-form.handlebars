<section class="panel form-panel">
  <div class="panel-head">
    <h1 class="form-title">{{formTitle}}</h1>
  </div>

  <p class="form-intro">{{formIntro}}</p>

  {{#if errorMessage}}
    <p class="error-text" aria-live="polite">{{errorMessage}}</p>
  {{/if}}

  <form class="stack-form" method="POST" action="{{formAction}}" enctype="multipart/form-data">
    <label>
      Nombre
      <input type="text" name="nombre" value="{{artist.nombre}}" autocomplete="name" required />
    </label>

    <label>
      Genero
      <select name="genero" id="genero" onchange="toggleNuevoGenero(this.value)">
        {{#each generos}}
          <option value="{{this}}" {{#if (eq ../artist.genero this)}}selected{{/if}}>{{this}}</option>
        {{/each}}
        <option value="nuevo">+ Nuevo género</option>
      </select>
    </label>

    <div id="nuevo-genero" style="display:none;">
      <label>
        Nombre del género
        <input type="text" id="nuevo-genero-input" name="generoNuevo" autocomplete="off" />
      </label>
    </div>

    <label>
      Pais
      <input type="text" name="pais" value="{{artist.pais}}" autocomplete="country-name" required />
    </label>

    <label for="foto">
      Foto del artista (opcional)
      <input type="file" id="foto" name="foto" accept="image/*" />
    </label>

    <div class="form-actions">
      <button class="button" type="submit">{{submitLabel}}</button>
      <a class="button button--ghost" href="/">Volver</a>
    </div>
  </form>
</section>