{{#if errorMessage}}
  <section class="panel">
    <p class="error-text" aria-live="polite">{{errorMessage}}</p>
  </section>
{{else}}
  {{#if feedback}}
    <section class="notice notice--{{feedback.tone}}" aria-live="polite">
      <p>{{feedback.message}}</p>
    </section>
  {{/if}}

  <section class="detail-hero panel">
    <div>
      <p class="eyebrow">{{artist.genero}}</p>
      <h1 class="detail-title">{{artist.nombre}}</h1>
      <p>{{artist.pais}}</p>
    </div>

    <div class="detail-stats">
      <div>
        <span>Canciones</span>
        <strong>{{artist.canciones.length}}</strong>
      </div>
      <div>
        <span>Duracion total</span>
        <strong>{{artist.duracionTotal}}</strong>
      </div>
    </div>
  </section>

  <section class="grid-layout">
    <div class="panel">
      <div class="panel-head">
        <h2>Canciones</h2>
        <a class="button button--ghost" href="/artistas/{{artist.id}}/editar">Editar artista</a>
      </div>

      {{#if artist.canciones.length}}
        <div class="song-list">
          {{#each artist.canciones}}
            <article class="song-row">
              <div>
                <strong>{{titulo}}</strong>
                <p class="song-meta">{{album}} &middot; {{duracionTexto}}</p>
              </div>

              <div class="song-actions">
                <span class="play-count">{{reproducciones}} reproducciones</span>
                <form method="POST" action="/canciones/{{id}}/reproducir">
                <button class="btn-play" type="submit">▶ Reproducir</button>
                </form>
                <form method="POST" action="/canciones/{{id}}/eliminar" onsubmit="return confirm('Eliminar esta cancion?');">
                  <button class="btn-danger" type="submit">Eliminar</button>
                </form>
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <p class="empty-state">Este artista aun no tiene canciones cargadas.</p>
      {{/if}}
    </div>

    <aside class="panel sidebar">
      <div class="panel-head">
        <h2>Agregar cancion</h2>
      </div>

      <form class="stack-form" method="POST" action="/artistas/{{artist.id}}/canciones">
        <label>
          Titulo
          <input type="text" name="titulo" autocomplete="off" required />
        </label>
        <label>
          Album
          <input type="text" name="album" autocomplete="off" required />
        </label>
        <label>
          Duracion (segundos)
          <input type="number" name="duracion" min="1" inputmode="numeric" required />
        </label>
        <button class="btn-save" type="submit">Guardar canción</button>
      </form>

      <p class="danger-copy">Esta accion borra el artista y todas las canciones asociadas.</p>

      <form class="danger-zone" method="POST" action="/artistas/{{artist.id}}/eliminar" onsubmit="return confirm('Eliminar este artista y todas sus canciones?');">
        <button class="btn-danger" type="submit">Eliminar artista</button>
      </form>
    </aside>
  </section>
{{/if}}
