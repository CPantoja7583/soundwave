{{#if errorMessage}}
  <section class="panel">
    <p class="error-text" aria-live="polite">{{errorMessage}}</p>
  </section>
{{else}}

  {{#if feedback}}
    <section class="notice notice--{{feedback.tone}}" aria-live="polite">
      <p>{{feedback.message}}</p>
    </section>
  {{/if}}

  <section class="detail-hero">
    <div class="detail-hero__bg">
      {{#if artist.foto}}
        <img src="/uploads/artistas/{{artist.foto}}" alt="{{artist.nombre}}" class="detail-hero__bg-img" />
      {{/if}}
      <div class="detail-hero__overlay"></div>
    </div>

    {{#if authUser}}
      <a class="detail-hero__edit" href="/artistas/{{artist.id}}/editar">Editar artista</a>
    {{else}}
      <a class="detail-hero__edit" href="/login?next=/artistas/{{artist.id}}/editar">Editar artista</a>
    {{/if}}

    <div class="detail-hero__content">
      <div class="detail-hero__left">
        <div class="detail-hero__avatar">
          {{#if artist.foto}}
            <img src="/uploads/artistas/{{artist.foto}}" alt="{{artist.nombre}}" />
          {{else}}
            <span>🎤</span>
          {{/if}}
        </div>
        <div class="detail-hero__info">
          <p class="detail-hero__genre">{{artist.genero}}</p>
          <h1 class="detail-title">{{artist.nombre}}</h1>
          <p class="detail-hero__country">{{artist.pais}}</p>
        </div>
      </div>

      <div class="detail-hero__stats">
        <div class="detail-hero__stat">
          <span>Canciones</span>
          <strong>{{artist.canciones.length}}</strong>
        </div>
        <div class="detail-hero__stat">
          <span>Duración total</span>
          <strong>{{artist.duracionTotal}}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="grid-layout">
    <div class="panel">
      <div class="panel-head">
        <h2>Canciones</h2>
      </div>

      {{#if artist.canciones.length}}
        <div class="song-list">
          {{#each artist.canciones}}
            <article class="song-row">
              <div class="song-cover">
                {{#if album.portada}}
                  <img src="/uploads/albums/{{album.portada}}" alt="{{album.nombre}}" class="song-cover__img" />
                {{else}}
                  <span class="song-cover__empty">🎵</span>
                {{/if}}
              </div>

              <div class="song-info">
                <strong class="song-title">{{titulo}}</strong>
                <p class="song-meta">{{album.nombre}} &middot; {{duracionTexto}}</p>
                <span class="play-count">{{reproducciones}} reproducciones</span>
              </div>

              <div class="song-actions">
                <form method="POST" action="/canciones/{{id}}/reproducir">
                  <button class="btn-play" type="submit">▶ Reproducir</button>
                </form>
                {{#if @root.authUser}}
                  <a class="btn-play" href="/canciones/{{id}}/editar">Editar</a>
                  <form method="POST" action="/canciones/{{id}}/eliminar"
                    onsubmit="return confirm('Eliminar esta canción?');">
                    <button class="btn-danger" type="submit">Eliminar</button>
                  </form>
                {{else}}
                  <a class="btn-play" href="/login?next=/canciones/{{id}}/editar">Editar</a>
                  <a class="btn-danger" href="/login?next=/artistas/{{../artist.id}}">Eliminar</a>
                {{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <p class="empty-state">Este artista aún no tiene canciones cargadas.</p>
      {{/if}}
    </div>

    <aside class="sidebar">
      <div class="panel">
        <div class="panel-head">
          <h2>Álbumes</h2>
          <span class="count-pill">{{artist.albums.length}}</span>
        </div>

        {{#if artist.albums.length}}
          <ul class="album-list">
            {{#each artist.albums}}
              <li class="album-item">
                {{#if portada}}
                  <img src="/uploads/albums/{{portada}}" alt="{{nombre}}" class="album-thumb" />
                {{else}}
                  <span class="album-thumb--vacio">🎵</span>
                {{/if}}
                <span>{{nombre}}</span>
                {{#if @root.authUser}}
                  <a class="btn-play" href="/albums/{{id}}/editar">Editar</a>
                {{else}}
                  <a class="btn-play" href="/login?next=/albums/{{id}}/editar">Editar</a>
                {{/if}}
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="empty-state">No hay álbumes aún.</p>
        {{/if}}
      </div>

      {{#if authUser}}
        <div class="panel">
          <div class="panel-head">
            <h2>Agregar canción</h2>
          </div>

          <form class="stack-form" method="POST"
            action="/artistas/{{artist.id}}/canciones"
            enctype="multipart/form-data">

            <label>
              Título
              <input type="text" name="titulo" autocomplete="off" required />
            </label>

            <label>
              Álbum
              <select name="albumId" id="albumId" onchange="toggleNuevoAlbum(this.value)">
                {{#each artist.albums}}
                  <option value="{{id}}">{{nombre}}</option>
                {{/each}}
                <option value="nuevo">+ Nuevo álbum</option>
              </select>
            </label>

            <div id="nuevo-album" style="display:none; gap:14px; flex-direction:column;">
              <label>
                Nombre del álbum
                <input type="text" name="nuevoAlbum" autocomplete="off" />
              </label>
              <label>
                Portada del álbum (opcional)
                <input type="file" name="portada" accept="image/*" />
              </label>
            </div>

            <label>
              Duración (segundos)
              <input type="number" name="duracion" min="1" inputmode="numeric" required />
            </label>

            <label>
              Link de YouTube
              <input type="url" name="youtube_url" placeholder="https://www.youtube.com/watch?v=..." required />
            </label>

            <button class="btn-save" type="submit">Guardar canción</button>
          </form>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Zona de peligro</h2>
          </div>
          <p class="danger-copy">Esta acción borra el artista y todas las canciones asociadas.</p>
          <form class="danger-zone" method="POST"
            action="/artistas/{{artist.id}}/eliminar"
            onsubmit="return confirm('Eliminar este artista y todas sus canciones?');">
            <button class="btn-danger" type="submit">Eliminar artista</button>
          </form>
        </div>
      {{else}}
        <div class="panel">
          <div class="panel-head">
            <h2>Agregar canci?n</h2>
          </div>
          <p class="empty-state">Inicia sesi?n para agregar canciones a este artista.</p>
          <a class="btn-save" href="/login?next=/artistas/{{artist.id}}">Login para agregar canci?n</a>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Zona de peligro</h2>
          </div>
          <p class="danger-copy">Inicia sesi?n para eliminar este artista.</p>
          <a class="btn-danger" href="/login?next=/artistas/{{artist.id}}">Login para eliminar artista</a>
        </div>
      {{/if}}
    </aside>
  </section>

{{/if}}
